# GnT Player Agent — Environment Configuration
# Copy this to .env and fill in values.
# The agent runs in demo mode (smart scripted conversations) with NO keys at all.

# ─── AI Provider (pick one) ───────────────────────────────────
# Google Gemini (free tier — recommended for demos)
# GOOGLE_API_KEY=AIza...
# Multiple keys for auto-rotation on rate limits (comma-separated):
# GOOGLE_API_KEYS=AIza...key1,AIza...key2,AIza...key3

# Anthropic Claude (paid API)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Sui Blockchain ──────────────────────────────────────────
SUI_NETWORK=testnet
# SUI_PRIVATE_KEY=suiprivkey1...
# SUI_PACKAGE_ID=0x...
# SEAL_PACKAGE_ID=0x...

# ─── Sui Messaging SDK ───────────────────────────────────────
# Real on-chain message encryption via Sui Groups
MESSAGING_ENABLED=true

# ─── Walrus Decentralized Storage ─────────────────────────────
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ─── Slack Bot (optional) ────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=

# ─── GnT Production MCP (optional) ───────────────────────────
# GNT_MCP_ENDPOINT=https://v2.gnt.ai/mcp/gnt
# GNT_MCP_API_KEY=

# ─── Server ──────────────────────────────────────────────────
# PORT=3847
